# .env Configuration

# SQLite Development Environment
DATABASE_URL="sqlite:./dev.db"
DEBUG=true

# Supabase Production Environment
SUPABASE_URL="https://your-supabase-url.supabase.co"
SUPABASE_KEY="your-supabase-key"

# StackBlitz Bolt Integration
STACKBLITZ_API_KEY=""
STACKBLITZ_BASE_URL="https://bolt.new"
STACKBLITZ_EMBED_URL="https://stackblitz.com/edit"
STACKBLITZ_PROJECT_ID=""
STACKBLITZ_TEMPLATE="node"
STACKBLITZ_OPEN_FILE="index.js"

# Other configurations
# Add any additional keys or settings as needed

# Developer Settings
DEV_DEBUG_MODE=false
DEV_LOG_LEVEL=error
DEV_LOG_HTTP_REQUESTS=false
DEV_LOG_QUERIES=false
DEV_API_RATE_LIMIT=60
DEV_CACHE_DRIVER=file
DEV_ENABLE_CORS=false
DEV_CORS_ORIGINS=*
DEV_API_DOCS_ENABLED=false
DEV_MAINTENANCE_MODE=false