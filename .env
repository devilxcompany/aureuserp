# .env Configuration

# SQLite Development Environment
DATABASE_URL="sqlite:./dev.db"
DEBUG=true

# Supabase Production Environment
SUPABASE_URL="https://your-supabase-url.supabase.co"
SUPABASE_KEY="your-supabase-key"

# Other configurations
# Add any additional keys or settings as needed

# ── GitHub Integration ────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/github/oauth/callback

# Secret used to verify incoming webhook payloads (set the same value in your
# GitHub repository's webhook settings under "Secret")
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Optional: default repository for ERP data exports
GITHUB_DEFAULT_REPO_OWNER=your-github-username
GITHUB_DEFAULT_REPO_NAME=aureuserp-data