# .env Configuration

# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# SQLite Development Environment
DATABASE_URL="sqlite:./dev.db"

# ============================================================
# INTEGRATION SETTINGS
# ============================================================
INTEGRATIONS_ENABLED=true
INTEGRATION_LOG_LEVEL=info

# ============================================================
# GITHUB INTEGRATION
# ============================================================
GITHUB_INTEGRATION_ENABLED=true
# Personal access token (needs repo + issues scopes)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=devilxcompany
GITHUB_REPO=aureuserp
# Set a secret in your GitHub repo webhook settings
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
GITHUB_API_URL=https://api.github.com
GITHUB_SYNC_ISSUES=true
GITHUB_SYNC_RELEASES=true

# ============================================================
# PABBLY CONNECT INTEGRATION
# ============================================================
PABBLY_ENABLED=true
PABBLY_API_KEY=your_pabbly_api_key
# The URL Pabbly sends data TO (your ERP webhook endpoint)
PABBLY_WEBHOOK_URL=https://your-domain.com/api/pabbly/webhook
PABBLY_VERIFY_SIGNATURE=true
PABBLY_LOG_WEBHOOKS=true
PABBLY_RETRY_ATTEMPTS=3
PABBLY_RETRY_DELAY=60

# ============================================================
# SUPABASE INTEGRATION
# ============================================================
SUPABASE_ENABLED=true
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_DB_HOST=db.your-supabase-url.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password

# ============================================================
# BOLT CMS INTEGRATION (Two Sites)
# ============================================================
BOLT_CMS_ENABLED=true
BOLT_CMS_SITE1_URL=https://your-bolt-site1.com
BOLT_CMS_SITE1_API_KEY=your_bolt_site1_api_key
BOLT_CMS_SITE2_URL=https://your-bolt-site2.com
BOLT_CMS_SITE2_API_KEY=your_bolt_site2_api_key
# Token to verify incoming Bolt CMS webhooks
BOLT_CMS_WEBHOOK_TOKEN=your_bolt_cms_webhook_token
BOLT_CMS_SYNC_CONTENT=true

# ============================================================
# QUEUE CONFIGURATION
# ============================================================
INTEGRATION_QUEUE_DRIVER=database
INTEGRATION_QUEUE_CONNECTION=default
INTEGRATION_QUEUE_MAX_ATTEMPTS=3
INTEGRATION_QUEUE_RETRY_AFTER=90
INTEGRATION_QUEUE_TIMEOUT=60

# ============================================================
# DATA SYNC SETTINGS
# ============================================================
SYNC_BATCH_SIZE=100
SYNC_CONFLICT_RESOLUTION=latest_wins
SYNC_DUPLICATE_PREVENTION=true
SYNC_AUTO_INTERVAL=300

# ============================================================
# MONITORING
# ============================================================
MONITORING_ENABLED=true
MONITORING_ALERT_EMAIL=admin@yourcompany.com
HEALTH_CHECK_INTERVAL=60
MAX_FAILURE_THRESHOLD=5