# ============================================================
# AureusERP - Environment Variables Example
# ============================================================
# Copy this to .env and fill in the values
# ============================================================

APP_NAME="AureusERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite (default for development)
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=aureuserp
# DB_USERNAME=root
# DB_PASSWORD=

# Supabase (optional)
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_KEY=your-supabase-key

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@aureuserp.local
MAIL_FROM_NAME="${APP_NAME}"

# Pabbly Connect
PABBLY_WEBHOOK_URL=http://localhost:8000/api/pabbly/webhook
PABBLY_API_KEY=
VERIFY_WEBHOOK_SIGNATURE=false
LOG_PABBLY_WEBHOOKS=true

# Frontend CORS
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8000
